# Simos Tuning Suite — .gitignore

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.whl

# ── PyInstaller ───────────────────────────────────────────────────────────────
# Keep spec, hooks, and version info in repo — exclude build artifacts
*.spec.bak
build/
dist/
*.manifest

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── IDE / editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Build assets (keep .ico if added) ────────────────────────────────────────
build_assets/*.png
build_assets/*.bmp
build_assets/README.md

# ── ODIS / diagnostic files — never commit these ─────────────────────────────
*.sd.db
*.sd.key
*.bv.db
*.bv.key
*.odx
*.pdx
*.frf
*.sgo
*.bin          # CAL binaries — user's own files, not for repo
*.zip          # Flashdaten archives

# ── Logs and session data ─────────────────────────────────────────────────────
*.log
*.csv
logs/
sessions/
*_probe.json
*_probe_*.json

# ── CP routine ID — keep the committed stub, ignore local overrides ───────────
# cp_tools/cp_routine_id.json is committed with confirmed=false
# DO NOT gitignore it — it's the canonical research output

# ── Test / temp ───────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.tmp
/tmp/
